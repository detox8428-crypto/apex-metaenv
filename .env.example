# APEX Email Integration Configuration
# Copy this file to .env and fill in your credentials

# Email Provider Selection
# Options: "gmail", "outlook", "smtp"
EMAIL_PROVIDER=gmail

# Gmail Configuration (when EMAIL_PROVIDER=gmail)
# Get app password from: https://support.google.com/accounts/answer/185833
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Outlook Configuration (when EMAIL_PROVIDER=outlook)
# Works with @outlook.com, @hotmail.com, @live.com addresses  
# Get app password from: https://account.microsoft.com/account/manage-my-microsoft-account
OUTLOOK_EMAIL=your-email@outlook.com
OUTLOOK_PASSWORD=your-app-password

# Custom SMTP Configuration (when EMAIL_PROVIDER=smtp)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-password

# Optional: Custom Contact Mapping
# Format: CONTACT_1_EMAIL=john@company.com
# Format: CONTACT_1_NAME=John Smith
CONTACT_1_EMAIL=
CONTACT_1_NAME=
CONTACT_2_EMAIL=
CONTACT_2_NAME=

# Note: Leave empty if you want to keep email in simulation-only mode
