# APEX Environment - Docker Configuration (.env.example)
# Copy this file to .env and modify as needed

# Logging
LOG_LEVEL=info

# Python configuration
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Container configuration
CONTAINER_NAME=apex-app
IMAGE_NAME=apex-app:latest

# Port configuration
PORT=8000
HOST=0.0.0.0

# Project name (in case you have multiple APEX instances)
PROJECT_NAME=apex-environment

# API configuration
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30

# Development flags
DEBUG=false
DEVELOPMENT_MODE=false
